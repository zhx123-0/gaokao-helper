.page{padding:30rpx;background:#f5f5f0;min-height:100vh;color:#111}
.hero{text-align:center;padding:50rpx 0}
.mine-avatar{width:120rpx;height:120rpx;border-radius:50%;border:3rpx solid #6366f1;margin-bottom:16rpx}
.name{font-size:36rpx;font-weight:700;color:#111;margin-bottom:8rpx}
.tagline{font-size:26rpx;color:#888;margin-bottom:30rpx}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;border:1rpx solid #e5e5e0}
.card-title{font-size:30rpx;font-weight:700;color:#111;margin-bottom:16rpx}
.info-row{font-size:26rpx;color:#555;padding:10rpx 0;display:flex;justify-content:space-between}
.label{color:#888}
.quote-v{font-size:28rpx;color:#888;line-height:2;text-align:center;padding:20rpx 0}
