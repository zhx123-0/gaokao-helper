<view class="page" style="position:relative;z-index:1">
  <image class="page-bg" src="{{bgImage}}" mode="aspectFill" wx:if="{{bgImage}}"/>
  <view class="hero-bar">
    <view class="hero-text">🤖 AI 助手</view>
    <view class="hero-desc">假期规划 · 旅行推荐</view>
  </view>

  <view class="tabs">
    <view class="tab {{mode==='plan'?'on':''}}" bindtap="setMode" data-m="plan">📅 假期规划</view>
    <view class="tab {{mode==='travel'?'on':''}}" bindtap="setMode" data-m="travel">🗺️ 旅行推荐</view>
  </view>

  <!-- 假期规划 -->
  <view wx:if="{{mode==='plan'}}">
    <view class="card">
      <view class="card-title">定制你的假期</view>
      <textarea class="input area" placeholder="我想做什么？喜欢什么？预算？天数？..." value="{{planInput}}" bindinput="onPlanInput"/>
      <view class="big-btn" bindtap="askPlan" wx:if="{{!pLoading}}">✨ AI生成假期计划</view>
      <view class="big-btn loading-btn" wx:if="{{pLoading}}"><text class="spin-drop">💧</text> 今天你喝水了吗？</view>
    </view>
  </view>

  <!-- 旅行 -->
  <view wx:if="{{mode==='travel'}}">
    <view class="card">
      <view class="card-title">AI 旅行规划</view>
      <textarea class="input area" placeholder="想去哪里？预算多少？几天？..." value="{{travelInput}}" bindinput="onTravelInput"/>
      <view class="big-btn orange" bindtap="askTravel" wx:if="{{!tLoading}}">✨ AI推荐旅行路线</view>
      <view class="big-btn orange loading-btn" wx:if="{{tLoading}}"><text class="spin-drop">💧</text> 今天你喝水了吗？</view>
    </view>
  </view>

  <view class="card" wx:if="{{result}}" style="border-color:#6366f1">
    <view class="card-title">🤖 回复</view>
    <view class="ai-result">{{result}}</view>
  </view>

  <view class="card" wx:if="{{history.length}}">
    <view class="card-title">📋 历史 <text style="font-size:22rpx;color:#888;font-weight:400">· 点击查看</text></view>
    <view class="h-item" wx:for="{{history}}" wx:key="time" bindtap="showDetail" data-idx="{{index}}">
      <view class="h-tag">{{item.mode}}</view>
      <view class="h-hobby">{{item.preview}}</view>
      <view class="h-time">{{item.time}}</view>
      <view class="h-arr">›</view>
    </view>
  </view>
</view>
