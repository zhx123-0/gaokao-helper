.page{padding:30rpx;min-height:100vh;color:#111}
.hero-bar{background:linear-gradient(135deg,#6366f1,#a78bfa);border-radius:20rpx;padding:40rpx 30rpx;margin-bottom:16rpx;color:#fff}
.hero-text{font-size:36rpx;font-weight:700;margin-bottom:8rpx}
.hero-desc{font-size:26rpx;opacity:.85}
.tabs{display:flex;gap:12rpx;margin-bottom:20rpx}
.tab{flex:1;text-align:center;padding:18rpx 0;background:rgba(255,255,255,.9);border-radius:14rpx;font-size:26rpx;border:2rpx solid transparent;transition:all .2s}
.tab.on{border-color:#6366f1;background:rgba(99,102,241,.06);font-weight:600;color:#6366f1}
.card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:28rpx;margin-bottom:20rpx;border:1rpx solid #e5e5e0}
.card-title{font-size:30rpx;font-weight:700;color:#111;margin-bottom:16rpx}
.input{background:#f5f5f0;border-radius:12rpx;padding:26rpx 22rpx;min-height:60rpx;font-size:26rpx;width:100%;box-sizing:border-box;border:1rpx solid #e5e5e0;margin-bottom:14rpx}
.area{height:160rpx;padding-top:16rpx}
.big-btn{text-align:center;padding:24rpx;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border-radius:14rpx;font-size:30rpx;font-weight:700;box-shadow:0 6rpx 24rpx rgba(99,102,241,.3);animation:glowBtn 2s infinite}
.big-btn.orange{background:linear-gradient(135deg,#f59e0b,#ef4444)}
@keyframes glowBtn{0%,100%{box-shadow:0 6rpx 24rpx rgba(99,102,241,.3)}50%{box-shadow:0 8rpx 36rpx rgba(99,102,241,.5)}}
.big-btn:active{opacity:.85;transform:scale(.98)}
.ai-result{font-size:28rpx;line-height:2;white-space:pre-wrap}
.h-item{display:flex;align-items:center;gap:10rpx;padding:16rpx 0;border-bottom:1rpx solid #f0f0eb}
.h-tag{font-size:22rpx;background:#eff6ff;color:#6366f1;padding:4rpx 12rpx;border-radius:6rpx;min-width:50rpx;text-align:center}
.h-hobby{flex:1;font-size:26rpx;color:#555;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.h-time{font-size:22rpx;color:#aaa}
.h-arr{font-size:36rpx;color:#ccc}
.loading-btn{opacity:.7}
