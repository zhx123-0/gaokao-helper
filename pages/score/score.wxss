.page{padding:30rpx;min-height:100vh;color:#111}
.hero{text-align:center;padding:40rpx 0 30rpx}
.hero-icon{font-size:64rpx;margin-bottom:12rpx}
.hero-title{font-size:36rpx;font-weight:800;color:#111;margin-bottom:8rpx}
.hero-sub{font-size:26rpx;color:#888}
.card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:28rpx;margin-bottom:20rpx;border:1rpx solid #e5e5e0}
.card-title{font-size:30rpx;font-weight:700;margin-bottom:16rpx}
.form-group{margin-bottom:20rpx}
.label{font-size:28rpx;color:#555;margin-bottom:10rpx;font-weight:500}
.input{background:#f5f5f0;border-radius:12rpx;padding:22rpx;height:50rpx;line-height:50rpx;font-size:26rpx;width:100%;box-sizing:border-box;border:1rpx solid #e5e5e0}
.area{height:140rpx;padding-top:16rpx;line-height:1.6}
.mood-row{display:flex;gap:14rpx;flex-wrap:wrap}
.mood{padding:14rpx 24rpx;background:#f5f5f0;border-radius:24rpx;font-size:26rpx;border:2rpx solid transparent}
.mood.on{border-color:#6366f1;background:rgba(99,102,241,.08);font-weight:600}
.big-btn{text-align:center;padding:24rpx;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border-radius:14rpx;font-size:30rpx;font-weight:700;box-shadow:0 6rpx 24rpx rgba(99,102,241,.3)}
.big-btn:active{opacity:.85}
.ai-result{font-size:28rpx;line-height:2;white-space:pre-wrap}
.history-item{display:flex;align-items:center;gap:14rpx;padding:16rpx 0;border-bottom:1rpx solid #f0f0eb}
.h-mood{font-size:36rpx}
.h-what{flex:1;font-size:26rpx;color:#555}
.h-time{font-size:22rpx;color:#aaa}
.h-arrow{font-size:36rpx;color:#ccc}
.loading-btn{opacity:.7}
