<view class="page" style="position:relative;z-index:1">
  <image class="page-bg" src="{{bgImage}}" mode="aspectFill" wx:if="{{bgImage}}"/>
  <view class="hero">
    <view class="hero-icon">📅</view>
    <view class="hero-title">高考后假期规划</view>
    <view class="hero-sub">三个阶段的假期规划清单 · 点击打卡 ✅</view>
  </view>

  <view class="section">
    <view class="section-title">📋 假期倒计时清单</view>
    <view class="checklist">
      <view class="check-item {{item.done ? 'done' : ''}}" wx:for="{{checklist}}" wx:key="id" bindtap="toggle" data-id="{{item.id}}">
        <view class="check-box {{item.done ? 'checked' : ''}}">{{item.done ? '✅' : ''}}</view>
        <view class="check-text">{{item.text}}</view>
        <view class="check-time" wx:if="{{item.time}}">{{item.time}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">🎯 三个阶段</view>
    <view class="phase-card" wx:for="{{phases}}" wx:key="title">
      <view class="phase-header">
        <view class="phase-num">{{index+1}}</view>
        <view class="phase-title">{{item.title}}</view>
        <view class="phase-time">{{item.time}}</view>
      </view>
      <view class="phase-items">
        <view class="phase-item" wx:for="{{item.items}}" wx:for-item="i" wx:key="*this">• {{i}}</view>
      </view>
    </view>
  </view>

</view>
