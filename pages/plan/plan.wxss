.page{padding:30rpx;background:#f5f5f0;min-height:100vh;color:#111}
.hero{text-align:center;padding:50rpx 0 40rpx}
.hero-icon{font-size:72rpx;margin-bottom:16rpx}
.hero-title{font-size:40rpx;font-weight:800;background:linear-gradient(135deg,#6366f1,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:10rpx}
.hero-sub{font-size:26rpx;color:#111}
.section{margin-bottom:36rpx}
.section-title{font-size:32rpx;font-weight:700;color:#111;margin-bottom:20rpx}
.check-item{display:flex;align-items:center;padding:20rpx;background:rgba(255,255,255,.95);border-radius:14rpx;margin-bottom:12rpx}
.check-item.done{opacity:.5}
.check-box{width:40rpx;height:40rpx;border:2rpx solid #334155;border-radius:50%;margin-right:16rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx}
.check-box.checked{border-color:#22c55e;background:rgba(34,197,94,.1)}
.check-text{flex:1;font-size:28rpx}.check-time{font-size:24rpx;color:#111}
.phase-card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:28rpx;margin-bottom:18rpx;border:1rpx solid #e5e5e0}
.phase-header{display:flex;align-items:center;gap:16rpx;margin-bottom:18rpx}
.phase-num{width:48rpx;height:48rpx;background:linear-gradient(135deg,#6366f1,#a78bfa);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:800;color:#111}
.phase-title{flex:1;font-size:30rpx;font-weight:700;color:#111}
.phase-time{font-size:24rpx;color:#111}
.phase-item{font-size:26rpx;color:#111;padding:8rpx 0}
.ai-card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:24rpx;margin-bottom:16rpx;border:1rpx solid #e5e5e0}
.ai-input{background:#f5f5f0;border-radius:12rpx;padding:20rpx;font-size:28rpx;width:100%;box-sizing:border-box;border:1rpx solid #e5e5e0;margin-bottom:14rpx}
.ai-btn{text-align:center;padding:20rpx;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border-radius:14rpx;font-size:28rpx;font-weight:600}
.ai-btn:active{opacity:.85}
.ai-result{font-size:28rpx;line-height:2}
