.page{padding:30rpx;background:#f5f5f0;min-height:100vh;color:#111}
.hero{text-align:center;padding:50rpx 0 40rpx}
.hero-icon{font-size:72rpx;margin-bottom:16rpx}
.hero-title{font-size:40rpx;font-weight:800;background:linear-gradient(135deg,#f59e0b,#ef4444);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:10rpx}
.hero-sub{font-size:26rpx;color:#111}
.filter-bar{display:flex;gap:14rpx;margin-bottom:30rpx;flex-wrap:wrap}
.filter-tag{padding:12rpx 28rpx;background:rgba(255,255,255,.95);border-radius:24rpx;font-size:26rpx;color:#111;transition:all .2s}
.filter-tag.active{background:#f59e0b;color:#0f0f1a;font-weight:600}
.dest-card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:28rpx;margin-bottom:18rpx;display:flex;gap:20rpx;border:1rpx solid #e5e5e0}
.dest-img{font-size:64rpx;width:80rpx;text-align:center}
.dest-info{flex:1}
.dest-name{font-size:32rpx;font-weight:700;color:#111;margin-bottom:8rpx}
.dest-tags{margin-bottom:10rpx}
.tag{display:inline-block;padding:6rpx 16rpx;background:rgba(245,158,11,.15);color:#f59e0b;border-radius:8rpx;font-size:22rpx;margin-right:12rpx}
.tag.price{background:rgba(34,197,94,.15);color:#22c55e}
.dest-desc{font-size:26rpx;color:#111;margin-bottom:8rpx;line-height:1.6}
.dest-route{font-size:24rpx;color:#111;margin-bottom:6rpx}
.dest-tip{font-size:24rpx;color:#f59e0b}
.tip-card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:28rpx;margin-top:20rpx;border:1rpx solid #e5e5e0}
.tip-title{font-size:30rpx;font-weight:700;color:#111;margin-bottom:16rpx}
.tip-item{font-size:26rpx;color:#111;padding:8rpx 0}
.section{margin-top:20rpx}
.sec-title{font-size:30rpx;font-weight:700;color:#111;margin-bottom:16rpx}
.ai-card{background:rgba(255,255,255,.95);border-radius:18rpx;padding:24rpx;margin-bottom:16rpx;border:1rpx solid #e5e5e0}
.ai-inp{background:#f5f5f0;border-radius:12rpx;padding:20rpx;font-size:28rpx;width:100%;box-sizing:border-box;border:1rpx solid #e5e5e0;margin-bottom:14rpx}
.ai-btn{text-align:center;padding:20rpx;background:linear-gradient(135deg,#f59e0b,#ef4444);color:#fff;border-radius:14rpx;font-size:28rpx;font-weight:600}
.ai-btn:active{opacity:.85}
.ai-result{font-size:28rpx;line-height:2}
