.page{padding-bottom:40rpx;background:#f5f5f0;min-height:100vh;color:#111}
.hero{position:relative;text-align:center;padding:60rpx 30rpx 40rpx;margin-bottom:30rpx;overflow:hidden}
.hero-bg{position:absolute;top:-80rpx;left:-80rpx;right:-80rpx;height:450rpx;background:radial-gradient(ellipse at center,rgba(99,102,241,.12) 0%,transparent 70%)}
.hero-avatar{width:120rpx;height:120rpx;border-radius:50%;border:3rpx solid #6366f1;margin:0 auto 20rpx;position:relative;z-index:1}
.hero-greeting{font-size:32rpx;font-weight:700;color:#111;margin-bottom:10rpx;position:relative;z-index:1}
.count-sub{font-size:24rpx;color:#888;margin-bottom:16rpx;position:relative;z-index:1}
.kapian{width:100%;border-radius:16rpx;position:relative;z-index:1}
.grid-2{display:flex;flex-wrap:wrap;padding:0 30rpx;margin-bottom:30rpx}
.entry-card{width:calc(50% - 10rpx);box-sizing:border-box;background:rgba(255,255,255,.95);border-radius:20rpx;padding:30rpx 20rpx;text-align:center;border:1rpx solid #e5e5e0;margin:0 10rpx 20rpx 0}
.entry-card:nth-child(2n){margin-right:0}
.entry-icon{font-size:48rpx;margin-bottom:12rpx}
.entry-name{font-size:28rpx;font-weight:700;color:#111}
