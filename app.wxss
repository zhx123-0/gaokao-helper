page{background:#f5f5f0;font-family:-apple-system,'PingFang SC',sans-serif;color:#111;line-height:1.6}
.page-bg{position:fixed;top:0;left:0;width:100%;height:100%;opacity:.25;z-index:0;pointer-events:none}
@keyframes spinDrop{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
.spin-drop{display:inline-block;animation:spinDrop 1.5s linear infinite}
